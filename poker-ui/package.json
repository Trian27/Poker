{
  "name": "poker-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview",
    "test:ui:smoke": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/gameplay.smoke.spec.ts --project=laptop --workers=1",
    "test:e2e:gameplay": "playwright test tests/e2e/gameplay.smoke.spec.ts --project=laptop --workers=1",
    "test:e2e:gameplay:full-stack": "playwright test tests/e2e/gameplay.full-stack.spec.ts --project=laptop --workers=1",
    "test:ui:smoke:headed": "playwright test --headed --project=phone-portrait --project=laptop",
    "test:ui:smoke:report": "playwright show-report"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.4",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^27.0.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "socket.io": "^4.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vitest": "^3.2.4",
    "vite": "^7.1.7"
  }
}
