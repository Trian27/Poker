APP_DOMAIN=beta.example.com
PUBLIC_APP_ORIGIN=https://beta.example.com
LETSENCRYPT_EMAIL=ops@example.com

POSTGRES_PASSWORD=change-me
JWT_SECRET_KEY=replace-with-openssl-rand-hex-32

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@example.com

INVITE_ONLY_REGISTRATION=true
BETA_INVITE_TTL_HOURS=168
EMAIL_VERIFICATION_EXPIRE_MINUTES=15

ADMIN_USERNAME=globaladmin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now
ADMIN_RESET_PASSWORD=false

G5_ADVISOR_TIMEOUT_SECONDS=5
G5_ENABLE_POSTFLOP_ANALYSIS=true
G5_RECENT_HANDS_COUNT=15
G5_PREFLOP_CHARTS_LEVEL=4
G5_DEBUG_RESPONSE=false

ENABLE_TEST_FIXTURE_API=false
